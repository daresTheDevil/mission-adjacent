{
  "name": "mission-adjacent-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Determinism-maximizing lint + type + property-test standard for TypeScript. Inspired by safety-critical coding standards. NOT certified for safety-critical use.",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "boundaries": "depcruise packages --config .dependency-cruiser.cjs",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "dependency-cruiser": "^17.4.3",
    "typescript": "catalog:"
  }
}
